    {
      "id": "aku",
      "tier": 1,
      "word": "aku",
      "translation": "ich / mich / mir / mein",
      "register": "informal",
      "notes": "Benutze 'aku' mit Freunden und Familie. Formell: 'saya'. In Jakarta auch 'gue'.",
      "examples": [
        { "indonesian": "aku makan", "german": "ich esse" },
        { "indonesian": "kamu lihat aku", "german": "du siehst mich" },
        { "indonesian": "itu punya aku", "german": "das gehört mir" }
      ]
    },
    {
      "id": "kamu",
      "tier": 1,
      "word": "kamu",
      "translation": "du / dich / dir / dein",
      "register": "informal",
      "notes": "Gegenstück zu 'aku'. In Jakarta auch 'lo'. Höflich: 'Pak/Bu/Mas/Mbak' statt 'kamu'.",
      "examples": [
        { "indonesian": "kamu tidur", "german": "du schläfst" },
        { "indonesian": "aku suka kamu", "german": "ich mag dich" }
      ]
    },
    {
      "id": "ya",
      "tier": 1,
      "word": "ya",
      "translation": "ja",
      "examples": [
        { "indonesian": "mau makan di sini? Ya.", "german": "Möchtest du hier essen? Ja." }
      ]
    },
